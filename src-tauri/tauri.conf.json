{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimpleVTube",
  "version": "0.1.0",
  "identifier": "com.simplevtube.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "control",
        "title": "SimpleVTube",
        "url": "index.html",
        "width": 420,
        "height": 640,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false
      },
      {
        "label": "character",
        "title": "SimpleVTube Character",
        "url": "character-window/index.html",
        "width": 400,
        "height": 400,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "emote",
        "title": "SimpleVTube Emote",
        "url": "emote-window/index.html",
        "width": 500,
        "height": 500,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}